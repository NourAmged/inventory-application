<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/style.css">
  <title>Searched Products</title>
</head>

<body>
  <%- include("navbar") %>
  <main class="searched-products">
    <h1 style="padding-bottom: 1rem;">You searched for "<%= search %>"</h1>
    <button class="return-btn" onclick="location.href = '/products'">
      &lt;&lt; Return to Products
    </button>
    <div class="products">
      <% if (products.length > 0) { %>
      <% products.forEach((product) => { %>
      <%- include('product', {product: product, categoryColor: categoryColor}); %>
      <%});%>
      <%} else {%>
      <p>No Products Found</p>
      <%};%>
    </div>
  </main>
</body>

</html>